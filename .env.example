# ===========================================================
# StudyMate AI — Environment Variables
# ===========================================================
# Copy this file to .env and fill in your values.

# Groq API Key (required)
# Get yours at: https://console.groq.com/keys
GROQ_API_KEY=ffghg

# LLM Configuration
LLM_PRIMARY_MODEL=llama-3.3-70b-versatile
LLM_FALLBACK_MODEL=qwen/qwen3-32b
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=4096

# FastAPI Configuration
API_HOST=127.0.0.1
API_PORT=8000
API_DEBUG=true

# Database
DATABASE_PATH=data/studymate.db

# Agent Configuration
AGENT_MAX_ITERATIONS=5
AGENT_MEMORY_WINDOW=20

# Logging
LOG_LEVEL=INFO
